{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Debug Web (Chrome)",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/src",
            "preLaunchTask": "Dev: Servidor local",
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/*"
            }
        },
        {
            "type": "android",
            "request": "launch",
            "name": "Debug Android (Build Completo)",
            "appSrcRoot": "${workspaceFolder}/android/app/src/main",
            "apkFile": "${workspaceFolder}/android/app/build/outputs/apk/debug/app-debug.apk",
            "adbArgs": [],
            "preLaunchTask": "Capacitor: Run Android"
        },
        {
            "type": "android",
            "request": "attach",
            "name": "Attach Android (App já rodando)",
            "appSrcRoot": "${workspaceFolder}/android/app/src/main",
            "adbArgs": [],
            "processId": "${command:PickAndroidProcess}"
        }
    ],
    "compounds": [
        {
            "name": "Build + Run Android + Logcat",
            "configurations": [
                "Debug Android (Build Completo)"
            ],
            "preLaunchTask": "Logcat: Limpar"
        }
    ]
}